# Public site URL (no trailing slash). Used in canonical, sitemap and OG tags.
NEXT_PUBLIC_SITE_URL=https://your-nexatel-domain.example

# Admin password (>= 6 chars). Required to log in at /admin/login.
ADMIN_PASSWORD=change-me-please

# Random 32+ char secret for signing the admin session cookie.
# Generate with:  openssl rand -hex 32
ADMIN_SESSION_SECRET=replace-with-32-plus-character-random-hex

# --- Email (optional, recommended) ---------------------------------
# Resend API key. If unset, submissions are still saved + visible in
# the admin panel, but no email is sent (the server logs them instead).
# Get a key at https://resend.com
RESEND_API_KEY=

# Verified sender. While testing on resend.dev, you can use:
#   Nexatel <onboarding@resend.dev>
# In production, verify a domain in Resend and use a real From address.
EMAIL_FROM="Nexatel <hello@nexatel.org>"
